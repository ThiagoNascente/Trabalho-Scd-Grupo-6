# ==========================================================================
# Configuração do deploy NATIVO na AWS (1 serviço por EC2, SEM Docker).
# --------------------------------------------------------------------------
# Copie para "env.aws" em CADA máquina e preencha. Os scripts deploy/aws/*.sh
# leem este arquivo. Você só precisa preencher de fato as linhas que o serviço
# daquela máquina usa — mas é mais simples manter UM env.aws igual em todas.
#
#   cp deploy/aws/env.aws.example deploy/aws/env.aws
#
# REGRA DE OURO dos endereços:
#   *_PRIVATE  -> IP PRIVADO da VPC: comunicação ENTRE serviços (backend↔backend).
#   *_PUBLIC   -> DNS/IP PÚBLICO da EC2: o que o NAVEGADOR acessa (só o frontend usa).
#
# Pegue o IP privado de cada EC2 no console (coluna "IP privado") ou com
# `hostname -I` dentro da máquina. O DNS público também está no console da EC2.
# ==========================================================================

# --- Segredos (IGUAIS em todas as máquinas) ---
# Gere um segredo forte: openssl rand -base64 48
JWT_SECRET=troque-por-um-segredo-forte-e-unico-de-32-ou-mais-caracteres

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=authdb
PG_PORT=5432
PG_HOST_PRIVATE=                 # IP privado da EC2 do Postgres (primário)
# Replicação (item 10) — opcional. Preencha só se for subir a réplica.
PG_REPL_USER=replicador
PG_REPL_PASSWORD=troque-a-senha-da-replica
PG_REPLICA_HOST_PRIVATE=         # IP privado da EC2 da réplica (se houver)
# Sub-rede privada da VPC autorizada no pg_hba (ex.: 172.31.0.0/16 na VPC padrão).
VPC_CIDR=172.31.0.0/16

# --- Redis ---
REDIS_PORT=6379
REDIS_HOST_PRIVATE=              # IP privado da EC2 do Redis

# --- Kafka ---
KAFKA_PORT=9092
KAFKA_HOST_PRIVATE=              # IP privado da EC2 do Kafka
MATCH_TOPIC=match-completed

# --- Auth Service (C#) ---
AUTH_PORT=5000
AUTH_GRPC_PORT=5005
AUTH_HOST_PRIVATE=               # IP privado da EC2 do Auth (gateway/engines chamam aqui)
AUTH_HOST_PUBLIC=                # DNS público da EC2 do Auth (o navegador faz login aqui)

# --- Gateway (Node) ---
GATEWAY_PORT=3000
GATEWAY_HOST_PUBLIC=             # DNS público da EC2 do Gateway (o navegador conecta aqui)

# --- Game Engines (1 por jogo) ---
# IP PRIVADO (o gateway abre a conexão-relay) e DNS PÚBLICO (o WebRTC conecta direto do navegador).
ENGINE1_HOST_PRIVATE=
ENGINE2_HOST_PRIVATE=
ENGINE3_HOST_PRIVATE=
ENGINE1_HOST_PUBLIC=
ENGINE2_HOST_PUBLIC=
ENGINE3_HOST_PUBLIC=
# Faixa de portas UDP/ICE do WebRTC (abrir no Security Group do engine).
GECKOS_UDP_MIN=20001
GECKOS_UDP_MAX=20030

# --- Score Service (Python) ---
SCORE_PORT=8000
SCORE_HOST_PUBLIC=               # DNS público da EC2 do Score (o navegador lê o ranking aqui)

# --- Frontend (Nginx) ---
FRONTEND_PORT=80
