# ==========================================================================
# Configuração do deploy NATIVO na AWS (6 máquinas condensadas, SEM Docker).
# --------------------------------------------------------------------------
# Copie para "env.aws" em CADA máquina e preencha. Os scripts deploy/aws/*.sh
# leem este arquivo. O mais simples é preencher UM env.aws completo no seu PC
# (com os IPs/DNS das 6 EC2) e copiá-lo igual para todas as máquinas.
#
#   cp deploy/aws/env.aws.example deploy/aws/env.aws
#
# REGRA DE OURO dos endereços:
#   *_PRIVATE  -> IP PRIVADO da VPC: comunicação ENTRE serviços (backend<->backend).
#   *_PUBLIC   -> DNS/IP PÚBLICO da EC2: o que o NAVEGADOR acessa.
#
# Pegue o IP privado de cada EC2 no console (coluna "IP privado") ou com
# `hostname -I` dentro da máquina. O DNS público também está no console da EC2.
#
# --------------------------------------------------------------------------
# MAPA DAS 6 MÁQUINAS (qual deployN roda o quê e quais endereços ele "é"):
#
#   deploy1  spaceship-data1     PostgreSQL primário + Redis
#            -> é o PG_HOST_PRIVATE e o REDIS_HOST_PRIVATE
#   deploy2  spaceship-data2     Kafka + PostgreSQL réplica
#            -> é o KAFKA_HOST_PRIVATE e o PG_REPLICA_HOST_PRIVATE
#   deploy3  spaceship-app       Auth + Gateway + Score + Frontend
#            -> é o AUTH_HOST_PRIVATE; e os três *_PUBLIC (AUTH/GATEWAY/SCORE)
#               recebem o MESMO DNS público: o da deploy3
#   deploy4  spaceship-engine1   Game Engine jogo1  -> ENGINE1_HOST_PRIVATE/PUBLIC
#   deploy5  spaceship-engine2   Game Engine jogo2  -> ENGINE2_HOST_PRIVATE/PUBLIC
#   deploy6  spaceship-engine3   Game Engine jogo3  -> ENGINE3_HOST_PRIVATE/PUBLIC
#
# Como vários serviços foram CONDENSADOS na mesma máquina, vários endereços
# apontam para o MESMO IP/DNS. Os comentários "# deployN" ao lado de cada
# variável dizem de qual máquina é aquele endereço.
# ==========================================================================

# --- Segredos (IGUAIS em todas as máquinas) ---
# Gere um segredo forte: openssl rand -base64 48
JWT_SECRET=troque-por-um-segredo-forte-e-unico-de-32-ou-mais-caracteres

# --- PostgreSQL (primário na deploy1; réplica na deploy2) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=authdb
PG_PORT=5432
PG_HOST_PRIVATE=                 # deploy1: IP PRIVADO da spaceship-data1 (primário)
# Replicação (item 10). A réplica (deploy2) copia o primário (deploy1) por aqui.
PG_REPL_USER=replicador
PG_REPL_PASSWORD=troque-a-senha-da-replica
PG_REPLICA_HOST_PRIVATE=         # deploy2: IP PRIVADO da spaceship-data2 (réplica)
# Sub-rede privada da VPC autorizada no pg_hba (ex.: 172.31.0.0/16 na VPC padrão).
VPC_CIDR=172.31.0.0/16

# --- Redis (na deploy1, junto do PostgreSQL primário) ---
REDIS_PORT=6379
REDIS_HOST_PRIVATE=              # deploy1: MESMO IP da spaceship-data1 (Redis mora junto do primário)

# --- Kafka (na deploy2, junto da réplica) ---
KAFKA_PORT=9092
KAFKA_HOST_PRIVATE=             # deploy2: IP PRIVADO da spaceship-data2 (Kafka mora junto da réplica)
MATCH_TOPIC=match-completed

# --- Auth Service (C#) — roda na deploy3 (spaceship-app) ---
AUTH_PORT=5000
AUTH_GRPC_PORT=5005
AUTH_HOST_PRIVATE=               # deploy3: IP PRIVADO da spaceship-app (gateway/engines validam aqui; o gRPC do gateway é nesta mesma máquina)
AUTH_HOST_PUBLIC=                # deploy3: DNS PÚBLICO da spaceship-app (o navegador faz login aqui)

# --- Gateway (Node) — roda na deploy3 (mesma máquina do Auth) ---
GATEWAY_PORT=3000
GATEWAY_HOST_PUBLIC=             # deploy3: MESMO DNS público da spaceship-app (gateway mora junto do Auth)

# --- Game Engines (1 por jogo, em máquinas separadas: deploy4/5/6) ---
# Só IP PRIVADO: o gateway abre a conexão-relay com cada engine pela rede interna
# da VPC. O navegador NÃO acessa os engines diretamente (fala só com o gateway).
ENGINE1_HOST_PRIVATE=            # deploy4: IP PRIVADO da spaceship-engine1 (jogo1)
ENGINE2_HOST_PRIVATE=            # deploy5: IP PRIVADO da spaceship-engine2 (jogo2)
ENGINE3_HOST_PRIVATE=            # deploy6: IP PRIVADO da spaceship-engine3 (jogo3)

# --- Score Service (Python) — roda na deploy3 (mesma máquina do Auth/Gateway) ---
SCORE_PORT=8000
SCORE_HOST_PUBLIC=               # deploy3: MESMO DNS público da spaceship-app (o navegador lê o ranking aqui)

# --- Frontend (Nginx) — roda na deploy3; é o site que você abre (porta 80) ---
FRONTEND_PORT=80
