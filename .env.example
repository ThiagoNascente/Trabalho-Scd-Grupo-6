# ==========================================================================
# Spaceship — Modelo de configuração de ambiente (BACKEND)
# --------------------------------------------------------------------------
# Copie este arquivo para ".env" e ajuste os valores conforme o ambiente
# (local, LAN ou nuvem). Centralizar a configuração aqui evita IPs/segredos
# "chumbados" no código e facilita os testes e o deploy na AWS (EC2).
#
#   cp .env.example .env
#
# O docker-compose.yml lê este .env. Sem POSTGRES_PASSWORD ou JWT_SECRET
# definidos, o `docker compose up` ABORTA com uma mensagem clara (e os
# serviços também abortam se subirem sem o segredo) — nenhum default é usado.
#
# A configuração do CLIENTE (host/portas usados pelo navegador) fica em
# frontend/config.js.
# ==========================================================================

# --- Banco de Dados (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=authdb
POSTGRES_PORT=5432

# --- Segredo do JWT (DEVE ser igual no Auth Service e no Game Gateway) ---
# Gere um segredo forte e único para produção (mínimo recomendado: 32+ chars).
# O docker-compose injeta este valor tanto no Auth (JwtSettings__Secret)
# quanto no Gateway (JWT_SECRET).
JWT_SECRET=troque-por-um-segredo-forte-e-unico-de-32-ou-mais-caracteres

# --- Auth Service (ASP.NET Core) ---
AUTH_PORT=5000
# Porta do endpoint gRPC do Auth (item 8 — validação de sessão chamada pelo gateway).
# HTTP/2 em texto puro (h2c); TLS está fora de escopo nesta versão.
AUTH_GRPC_PORT=5005
# OPCIONAL: só necessário para rodar o Auth Service FORA do Docker.
# No docker-compose a connection string é montada a partir das variáveis
# POSTGRES_* acima (Host=postgres). Descomente e ajuste para execução local:
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=authdb;Username=postgres;Password=troque-esta-senha

# --- Game Gateway (Node.js / Socket.io — relay) ---
# O gateway autentica, faz lobby e ROTEIA: para cada cliente abre uma conexão
# a cada Game Engine. Ele NÃO chama o Auth diretamente (os engines é que chamam).
GATEWAY_PORT=3000
# Validação de sessão via gRPC SÍNCRONO no Auth (item 8). host:porta gRPC do Auth.
# Em Docker, o nome do serviço; na AWS, o IP privado da EC2 do Auth (porta 5005).
# Vazio => o gateway valida o JWT localmente (modo DEV, sem regressão).
AUTH_GRPC_URL=auth-service:5005
# AUTH_GRPC_TIMEOUT_MS=2000   # opcional: timeout do RPC antes do fallback local
# Endereços dos engines vistos pelo gateway (em Docker, os nomes dos serviços).
ENGINE1_URL=http://game-engine-1:4001
ENGINE2_URL=http://game-engine-2:4002
ENGINE3_URL=http://game-engine-3:4003

# --- Game Engines (Node.js — 1 processo por jogo) ---
# Mesma imagem; GAME (jogo1|jogo2|jogo3) define qual física roda em cada um.
# O Jogo 1 usa AUTH_API_URL para gravar as vitórias (Wins) no Auth Service.
ENGINE1_PORT=4001
ENGINE2_PORT=4002
ENGINE3_PORT=4003
AUTH_API_URL=http://auth-service:5000/api/auth

# --- Mensageria (Kafka — item 4) ---
# Cada engine publica 'match-completed' ao fim da partida; o Score Service consome.
# No compose os engines usam o listener interno kafka:29092 (já configurado lá).
# Vazio/sem KAFKA_BROKER => publicação desativada (DEV sem Docker, sem regressão).
MATCH_TOPIC=match-completed
KAFKA_GROUP=score-service

# --- Score Service (Python/Flask — item 5) + Redis (item 6) ---
# Consome o Kafka, materializa o ranking por minigame no Redis e o histórico no
# PostgreSQL; expõe GET /api/scores. Endereços internos do compose abaixo.
SCORE_PORT=8000
REDIS_URL=redis://redis:6379/0
PG_HOST=postgres

# --- Frontend (Nginx) ---
FRONTEND_PORT=8080
