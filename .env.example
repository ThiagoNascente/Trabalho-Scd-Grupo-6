# ==========================================================================
# CosmoDock — Modelo de configuração de ambiente (BACKEND)
# --------------------------------------------------------------------------
# Copie este arquivo para ".env" e ajuste os valores conforme o ambiente
# (local, LAN ou nuvem). Centralizar a configuração aqui evita IPs/segredos
# "chumbados" no código e facilita os testes e o deploy na AWS (EC2).
#
# A configuração do CLIENTE (host/portas usados pelo navegador) fica em
# frontend/config.js.
# ==========================================================================

# --- Banco de Dados (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=authdb
POSTGRES_PORT=5432

# --- Auth Service (ASP.NET Core) ---
# String de conexão usada pelo Auth Service para acessar o Postgres.
# Em Docker Compose, "Host" é o nome do serviço (postgres).
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=authdb;Username=postgres;Password=troque-esta-senha
AUTH_PORT=5000

# --- Segredo do JWT (DEVE ser igual no Auth Service e no Game Gateway) ---
# Gere um segredo forte e único para produção.
JWT_SECRET=super_secret_key_that_should_be_long_enough_for_hmac_sha256_in_production

# --- Game Gateway (Node.js / Socket.io) ---
GATEWAY_PORT=3000
# URL interna do Auth Service usada pelo Gateway para validar/consultar dados.
AUTH_API_URL=http://auth-service:5000/api/auth

# --- Frontend (Nginx) ---
FRONTEND_PORT=8080
